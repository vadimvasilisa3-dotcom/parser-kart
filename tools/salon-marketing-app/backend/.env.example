# Ключи ВК и Яндекс — можно НЕ заполнять.
# Программа работает и без них. Заполняйте только если хотите кнопку «Подключить».
#
# Проще: вкладка «Интеграции» → вставьте ключи прямо в поля (без этого файла).
#
VK_CLIENT_ID=
VK_CLIENT_SECRET=
YANDEX_CLIENT_ID=
YANDEX_CLIENT_SECRET=
OAUTH_REDIRECT_BASE=http://127.0.0.1:8000
FRONTEND_URL=http://127.0.0.1:8777
TOKENS_DB_PATH=tokens.sqlite3
